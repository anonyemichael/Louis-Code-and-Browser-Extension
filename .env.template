# Official Ollama Cloud API & Custom OpenAI-Compatible Endpoints (Mapped under Ollama provider)
# NOTE: Ollama hosts an official Cloud API (e.g. https://ollama.com). This also supports ANY Cloud API using OpenAI format (/v1/chat/completions).
OLLAMA_API_KEYS=YOUR_OLLAMA_KEY_HERE
OLLAMA_MODEL=qwen3-coder:480b

# OpenRouter Fallback (comma-separated keys for rotation on rate limits)
OPENROUTER_API_KEYS=YOUR_OPENROUTER_KEY_1,YOUR_OPENROUTER_KEY_2

# Multi-Agent Routing (each role uses the best model for the job)
CODER_MODEL=qwen3-coder:480b
PLANNER_MODEL=nemotron-3-super
GENERAL_MODEL=gemma4:31b

# Enhanced Web Search (optional — improves search reliability)
TAVILY_API_KEY=YOUR_TAVILY_KEY_HERE       # Free: 1,000 searches/month at tavily.com
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GOOGLE_CSE_ID=YOUR_GOOGLE_CSE_ID_HERE

# Browser Extension WebSocket Server
LOUIS_WS_PORT=7865
